# ──────────────────────────────────────────
# APLICAÇÃO
# ──────────────────────────────────────────
PORT=3000

# ──────────────────────────────────────────
# BANCO DE DADOS (usuário root — administração)
# ──────────────────────────────────────────
POSTGRES_USER=seu_usuario_admin
POSTGRES_PASSWORD=sua_senha_admin
POSTGRES_DB=seu_nome_banco

# ──────────────────────────────────────────
# BANCO DE DADOS (usuário da aplicação — menor privilégio)
# ──────────────────────────────────────────
APP_DB_USER=seu_usuario_aplicacao
APP_DB_PASSWORD=sua_senha_aplicacao

# ──────────────────────────────────────────
# URL DE CONEXÃO (usada pela aplicação e pelo Prisma no host)
# ──────────────────────────────────────────
# Substitua com os seus valores correspondentes
DATABASE_URL=postgresql://seu_usuario_aplicacao:sua_senha_aplicacao@localhost:5430/seu_nome_banco?schema=public&connection_limit=30&connect_timeout=30
